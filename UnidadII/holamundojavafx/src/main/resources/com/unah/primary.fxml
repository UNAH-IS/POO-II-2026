<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="358.0" prefWidth="380.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unah.PrimaryController">
   <children>
      <DatePicker />
      <RadioButton mnemonicParsing="false" text="RadioButton" />
      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
      <ProgressBar prefWidth="200.0" progress="0.0" />
      <ComboBox prefWidth="150.0" />
      <ChoiceBox prefWidth="150.0" />
      <CheckBox mnemonicParsing="false" text="CheckBox" />
      <Label text="Esta es la vista principal y la modificamos desde el Scene Builder" />
      <Button fx:id="primaryButton" onAction="#switchToSecondary" prefHeight="85.0" prefWidth="158.0" text="Cambiar a vista secundaria" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
